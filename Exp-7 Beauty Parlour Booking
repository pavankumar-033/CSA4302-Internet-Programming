<!DOCTYPE html>
<html>

<head>

<title>Beauty Parlour Booking</title>

<link rel="stylesheet" href="style.css">

</head>


<body>


<header>

<h1>💄 Glow Beauty Parlour</h1>

<nav>

<a href="#home">Home</a>
<a href="#services">Services</a>
<a href="#booking">Booking</a>
<a href="#admin">Admin</a>

</nav>

</header>




<section id="home">

<h2>Look Beautiful, Feel Confident ✨</h2>

<p>
Book your favourite beauty services with professional stylists.
</p>

</section>





<section id="services">

<h2>Our Services 💅</h2>


<div class="container">


<div class="card">

<div class="emoji">💇‍♀️</div>

<h3>Hair Styling</h3>

<p>Price : ₹500</p>

<button onclick="selectService('Hair Styling',500)">
Book Now
</button>

</div>



<div class="card">

<div class="emoji">💄</div>

<h3>Makeup</h3>

<p>Price : ₹1500</p>

<button onclick="selectService('Makeup',1500)">
Book Now
</button>

</div>




<div class="card">

<div class="emoji">💅</div>

<h3>Nail Art</h3>

<p>Price : ₹700</p>

<button onclick="selectService('Nail Art',700)">
Book Now
</button>

</div>




<div class="card">

<div class="emoji">🧖‍♀️</div>

<h3>Facial</h3>

<p>Price : ₹900</p>

<button onclick="selectService('Facial',900)">
Book Now
</button>

</div>


</div>


</section>






<section id="booking">


<h2>Appointment Booking 📅</h2>


<p id="selected">
No service selected
</p>


<input id="customer"
placeholder="Customer Name">


<select id="stylist">

<option>Select Stylist</option>

<option>Priya</option>

<option>Anitha</option>

<option>Divya</option>

</select>



<input type="date" id="date">


<input type="time" id="time">



<button onclick="bookAppointment()">

Confirm Booking & Pay 💳

</button>



<p id="message"></p>


</section>







<section id="admin">


<h2>Admin Panel 👩‍💼</h2>


<button onclick="viewAppointments()">

View Appointments

</button>


<p id="adminData"></p>


</section>






<footer>

<p>
© 2026 Glow Beauty Parlour
</p>

</footer>



<script src="javascript.js"></script>


</body>

</html>
